  publisher = {Oxford University Press},
  doi = {10.1093/oso/9780197637227.003.0011},
  urldate = {2023-09-07},
  abstract = {This chapter tracks the fortunes of repair as a motive for reading in recent discussions in literary studies, considering it alongside the eudaimonic turn. In her influential account of paranoid and reparative reading practices, Eve Kosofsky Sedgwick suggests a novel object for criticism: participation in an ``ecology of knowing'' that aims toward the repair of the person. Addressing recent discussions about critique and postcritique as well as the mood of criticism, this chapter tracks the possibilities for such a eudaimonic program in literary criticism. In particular, it is concerned with the place of joy and pleasure in Left literary and cultural criticism---especially in the fields of queer, critical race, and disability studies. To offer a broader context for these contemporary discussions, the chapter looks to the presence of happiness in the writings of Theodor Adorno. The chapter considers the politics of pain and pleasure in the work of Sedgewick and Adorno. It draws a connection between them on the basis of their sensitivity to experience, arguing that their attempt to stay close to their objects attunes them to the affective complexities of modernity.},
  isbn = {978-0-19-763722-7},
  file = {/Users/frednere/Zotero/storage/KNG6KGEC/Love - 2023 - Merely Ameliorative Reading, Critical Affect, and the Project of Repair.pdf;/Users/frednere/Zotero/storage/A8EXLN5P/378708613.html}

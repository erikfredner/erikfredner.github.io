  doi = {10.1093/ahr/rhaf010},
  urldate = {2025-06-12},
  abstract = {Mass digitized archival databases are anarchic, rhizomatic places. The search bar makes them this way. This is not to say that large-scale digital libraries and archives have no structure. A human-created interface shapes how we as users approach the human-selected documents, including opportunities to browse by theme, location, and document type.1 And yet the existence and centrality of the search bar, which is built on full-text search capabilities, means that, in the digital archive, it is up to us to create search vocabulary and make connections between the things we find in a way that is quite different from finding books on a library shelf, working through an archival box or folder or, chronologically, through a run of a newspaper. If items are ordered for us in the digital realm, it is in a virtually endless series of permutations, rearranged with each new keyword search and with each new document uploaded.2 In the absence of the expert guiding hand of the archivist or librarian, the archival becomes non-hierarchical, ``anarchival.''3},
  file = {/Users/frednere/Zotero/storage/TVXKGDEQ/Frydman - 2025 - In Defense of the Search Bar.pdf;/Users/frednere/Zotero/storage/3E8Z5N84/8158881.html}
}


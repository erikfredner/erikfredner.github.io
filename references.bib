@article{glaveyHavingCokeYou2019,
  title = {Having a {{Coke}} with {{You Is Even More Fun Than Ideology Critique}}},
  author = {Glavey, Brian},
  year = 2019,
  month = oct,
  journal = {PMLA/Publications of the Modern Language Association of America},
  volume = {134},

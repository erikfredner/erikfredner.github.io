@article{furediMoralPanicReading2016,
  title = {Moral {{Panic}} and {{Reading}}: {{Early Elite Anxieties About}} the {{Media Effect}}},
  shorttitle = {Moral {{Panic}} and {{Reading}}},
  author = {Furedi, Frank},

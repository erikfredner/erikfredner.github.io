@incollection{priceVictorianReading2012,
  title = {Victorian Reading},
  booktitle = {The {{Cambridge History}} of {{Victorian Literature}}},
  author = {Price, Leah},
  editor = {Flint, Kate},
  year = 2012,
  series = {The {{New Cambridge History}} of {{English Literature}}},
  pages = {34--55},
  publisher = {Cambridge University Press},
  address = {Cambridge},
  doi = {10.1017/CHOL9780521846257.004},
  urldate = {2023-10-14},
  abstract = {In 1847, Sir Arthur Helps began an essay on reading with the dutiful observation that `It appears to me remarkable that this subject should have been so little touched upon', but one sometimes feels that the Victorians touched on little else. Literacy was credited for reducing criminality and blamed for encouraging sexual licence; the topic fuelled both visual and verbal media, writing and speech. When twenty-first-century scholars gain access to nineteenth-century clich\'es about reading, they do so via print; but the Victorians themselves used the spoken word to praise writing. Sermons remained the traditional venue for arguments about the benefits and dangers of the printed word, but by the 1830s they faced secular competition from after-dinner speeches of benevolent organizations, lectures at the opening of mechanics' institutes, and public addresses like Ruskin's Sesame and Lilies -- not to mention Parliamentary debates, themselves transcribed in shorthand and read by many more people than those who had heard them. To read that record now is to remember how many of the policies over which Victorian MPs argued related, directly, or indirectly, to literacy. Schools, libraries, copyright law, postal rates, and above all the taxes that determined the pricing of printed matter: the institutions that the Victorians established, reformed, and attacked were centrally concerned with reading.},
  isbn = {978-1-139-02915-5},
  file = {/Users/frednere/Zotero/storage/WWMG9ELN/Price - 2012 - Victorian reading.pdf;/Users/frednere/Zotero/storage/RKZ9SW35/2FF0937020F2D0E3ECA476B1127EB81D.html}
}


  shorttitle = {Exploiting Affinities between Topic Modeling and the Sociological Perspective on Culture},
  author = {DiMaggio, Paul and Nag, Manish and Blei, David},
  year = 2013,
  month = dec,
  journal = {Poetics},
  series = {Topic {{Models}} and the {{Cultural Sciences}}},
  volume = {41},

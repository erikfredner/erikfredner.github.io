@book{frankSchoolsFictionLiterature2023,
  title = {Schools of Fiction: Literature and the Making of the American Educational System},
  shorttitle = {Schools of Fiction},
  author = {Frank, Morgan Day},
  year = 2023,
  series = {Oxford Studies in American Literary History - Cloth},
  publisher = {Oxford University Press},
  address = {New York},
  abstract = {"Schools of Fiction argues that the institutionalization of literature drove the expansion and consolidation of the modern school system in the United States after the Civil War. From our historical perspective, the study of literature may seem like a preeminently traditional academic subject, one that was superseded by the sciences long ago. The conviction that literature is marginal to the program of modern education has taken hold even (and especially) in English departments, where feelings of crisis have predominated since the founding of the discipline and where literature is more and more often understood as subject to the school's administrative imperatives. Against this abiding sense of crisis and abjection, Schools of Fiction reveals literature's profound influence on the development of US educational institutions, an influence derived, paradoxically, from its anti-institutionalism. Since the inception of the modern school, teachers have eagerly taught literary works that disparage formal education - preferring the anti-scholasticism of the American romance tradition to the didacticism of the sentimentalists, for instance, or embracing the novel form whose "very nature," in Mikhail Bakhtin's words, is "not canonic," or organizing "African American literature" as a discursive category around texts that despaired of the post-Reconstruction institutional system. As an object of classroom study that announces its own imperviousness to pedagogy and pedagoguery, literature has helped dissolve the boundaries dividing formal education from public life. It has embedded non-scholastic experience in the school's increasingly sophisticated administrative apparatus"--},
  isbn = {978-0-19-286750-6},
  file = {/Users/frednere/Zotero/storage/THB8E3IX/Frank - 2023 - Schools of fiction literature and the making of the american educational system.pdf}
}


@article{finnAppliedPoetics2024,
  title = {Applied {{Poetics}}},
  author = {Finn, Ed},
  year = 2024,
  month = jun,
  journal = {Poetics Today},
  volume = {45},
  number = {2},
  pages = {251--258},
  issn = {0333-5372},
  doi = {10.1215/03335372-11092857},
  urldate = {2024-06-11},
  abstract = {Poetics is the study of literature as ``a system of possibilities,'' distinguished from literary history, hermeneutics, and interpretation by its close attention to the function of words in relationship to one another (Culler 2020). Large language models (LLMs) and generative artificial intelligence (AI) are, in a very real sense, the expression of a very expensive, computationally intensive form of applied poetics, funded for the most part by the world's largest corporations. These systems do much more than string words together, of course: they can create and debug computer code, as well as interpret and generate images, sound, functional magnetic resonance imaging data, and more. There is something comically ironic about how decades of work in mathematical approaches to digitizing reality have finally led computer scientists back to language---with all its messy, ambiguous complexities---as the best critical aperture for understanding the world (Leibniz would be so pleased!). Speaking in March 2023, AI researchers Tristan Harris and Aza Raskin (2023) noted that, by treating each of these forms of data as a language, not only are the latest AI models advancing simultaneously in multiple fields, but breakthroughs and new findings in each field are also rapidly assimilated into language-based models as a whole. In other words, the state of the art is accelerating swiftly because language is proving to be such a universal system of possibilities.},
  file = {/Users/frednere/Zotero/storage/RR34J3DE/Finn - 2024 - Applied Poetics.pdf;/Users/frednere/Zotero/storage/ZVFMX63H/Applied-Poetics.html}
}


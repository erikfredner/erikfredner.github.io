@article{haylesHumanMachineCultures2018,
  title = {Human and {{Machine Cultures}} of {{Reading}}: {{A Cognitive-Assemblage Approach}}},
  shorttitle = {Human and {{Machine Cultures}} of {{Reading}}},
  author = {Hayles, N. Katherine},
  year = 2018,
  month = oct,
  journal = {PMLA},
  volume = {133},

@article{elamPoetryWillNot2023,
  title = {Poetry {{Will Not Optimize}}; or, {{What Is Literature}} to {{AI}}?},
  author = {Elam, Michele},
  year = 2023,
  month = jun,
  journal = {American Literature: A Journal of Literary History, Criticism, and Bibliography},
  volume = {95},
  number = {2},
  pages = {281--303},
  publisher = {Duke University Press},
  issn = {1527-2117},
  doi = {10.1215/00029831-10575077},
  urldate = {2025-08-15},
  abstract = {Literature, poetry, and other forms of noncommercial creative expression challenge the techno-instrumentalist approaches to language, the predictive language generation, informing NLP (large natural language processing models) such as GPT-3 or -4 as well as, more generally, generative AI (text to image, video, audio). Claims that AI systems automate and expedite creativity reflect industry and research priorities of speed, scale, optimization, and frictionlessness driving much artificial intelligence design and application. But poetry will not optimize; the creative process cannot be reduced to a prompt. Some have noted that literary creations generated or augmented by artificial intelligence at best can offer form without meaning; using a GPT creation prompted by Maya Angelou's poem ``Still I Rise'' as a case study, this essay argues that NLP's predictive language generation and what I call algorithmic ahistoricity can also, more disturbingly, render meaning senseless. In doing so, GPT-3's literary experiments are not ``failed'' because they do not meet some moving target of a literary standard, nor because of technological insufficiency, but because it can make it harder for people to name and navigate their realities. The coda explores an example of AI as literary interlocutor and creative engagement beyond optimization.},
  langid = {english},
  keywords = {1900-1999,American literature,And I Still Rise (1978),Angelou Maya (1928-2014),artificial intelligence,computer-generated literature,poetry,sociohistorical context},
  file = {/Users/frednere/Zotero/storage/B8I52EPJ/Elam - 2023 - Poetry Will Not Optimize; or, What Is Literature to AI.pdf}
}

